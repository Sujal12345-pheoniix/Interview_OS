# InterviewOS .gitignore

# ==================== Node / Frontend ====================
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.*.local
frontend/dist/
frontend/.turbo/
frontend/coverage/

# ==================== Python / Backend ====================
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.venv/
backend/venv/
backend/.env
backend/dist/
backend/build/
backend/*.egg-info/
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/celerybeat-schedule
backend/celerybeat.pid

# ==================== Environment ====================
.env
.env.local
.env.*.local
*.env
!.env.example
!**/.env.example
!**/.env.local.example

# ==================== IDEs ====================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==================== Logs ====================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==================== Docker ====================
docker-compose.override.yml

# ==================== Deployment ====================
.vercel/
.railway/
*.tfstate
*.tfstate.backup
.terraform/

# ==================== Testing ====================
coverage/
.nyc_output/
test-results/

# ==================== AI / ML ====================
*.pkl
*.model
models/
embeddings_cache/

# ==================== Uploads (use cloud storage) ====================
uploads/
backend/uploads/

# ==================== Misc ====================
*.bak
*.tmp
.cache/
